{
  "workbench.startupEditor": "none",
  "files.autoSave": "onFocusChange",
  "editor.fontFamily": "monofur",
  "editor.cursorBlinking": "expand",
  "workbench.activityBar.location": "hidden",
  "editor.minimap.enabled": false,
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": true,
  "editor.stickyScroll.enabled": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontLigatures": true,
  "editor.wordWrap": "on",
  "workbench.sideBar.location": "right",
  "terminal.integrated.fontFamily": "monofur",
  "editor.formatOnSaveMode": "modifications",
  "diffEditor.wordWrap": "off",
  "editor.formatOnSave": true,
  "editor.hideCursorInOverviewRuler": true,
  "editor.overviewRulerBorder": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "breadcrumbs.enabled": false,
  "workbench.tree.renderIndentGuides": "none",
  "editor.guides.indentation": false,
  "editor.renderLineHighlight": "none",
  "editor.glyphMargin": false,
  "editor.showFoldingControls": "never",
  "window.menuBarVisibility": "toggle",
  "workbench.layoutControl.type": "menu",
  "workbench.layoutControl.enabled": false,
  "workbench.statusBar.visible": false,
  "emmet.includeLanguages": {
    "blade.php": "html",
    "vue": "html"
  },
  "files.associations": {
    ".php_cs": "php",
    ".php_cs.dist": "php",
    "*.php": "php"
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    // Hide everything in /public, except "index.php"
    "**/public/[abcdefghjklmnopqrstuvwxyz]*": true,
    "**/public/i[abcdefghijklmopqrstuvwxyz]*": true,
    // Hide everything in /vendor, except "laravel" folder.
    "**/vendor/[abcdefghijkmnopqrstuvwxyz]*": true,
    "**/vendor/l[bcdefghijklmnopqrstuvwxyz]*": true,
    "storage/framework/views": true
  },
  "editor.codeLens": false,
  "editor.renderControlCharacters": false,
  "editor.renderWhitespace": "all",
  "editor.fontSize": 19,
  "editor.lineHeight": 27.5,
  "editor.letterSpacing": 0,
  "editor.suggestFontSize": 16,
  "editor.suggestLineHeight": 28,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.cursorStyle": "line",
  "editor.wordSeparators": "`~!@#%^&*()=+[{]}\\|;:'\",.<>/?",
  "editor.quickSuggestionsDelay": 0,
  "diffEditor.ignoreTrimWhitespace": false,
  "extensions.ignoreRecommendations": true,
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "php-docblocker.classTemplate": {
    "message": {
      "gapAfter": true
    },
    "param": {
      "gapBefore": true
    },
    "author": {
      "content": "@author ${###:Omar Gabriel} <${###:omareegab@gmail.com}>"
    }
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.colorTheme": "Aura Dracula Spirit (Synthwave)"
}

